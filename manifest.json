{
  "manifest_version": 3,
  "name": "FC Enhancer — Redesigned",
  "version": "4.0.0",
  "description": "Focused UI refactor for the FC Enhancer Trader screen: monochrome dark theme with emerald accent, separated cards, live purchase stats, consolidated saved-filters dropdown. Top navbar themed across all pages.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.ea.com/*",
    "https://*.ea.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.ea.com/*",
        "https://*.ea.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "FC Enhancer Redesign",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
